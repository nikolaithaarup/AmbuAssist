{
  "expo": {
    "name": "AmbuAssist",
    "slug": "ambuassist",
    "version": "1.1.2",
    "scheme": "ambuassist",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#25311F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dk.ambuassist.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow AmbuAssist to use your location to suggest the correct destination hospital and estimate driving time to selected hospitals.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dk.ambuassist.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/her-icon.png",
        "backgroundColor": "#25311F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow AmbuAssist to use your location to suggest the correct destination hospital and estimate driving time to selected hospitals."
        }
      ]
    ],
    "assetBundlePatterns": ["**/*"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2cf6988e-3c16-472f-aca2-1e9109d568f4"
      }
    }
  }
}
